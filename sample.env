# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
BOT_ID=YourBotUsernameWithout@

# ── Spotify (FREE developer account is enough) ────────────────────────────────
# spotDL uses /v1/tracks, /v1/albums, /v1/playlists — NOT /v1/search
# Free dev accounts work fine. Only /v1/search needs Premium (we don't use it).
# Get from: developer.spotify.com/dashboard → Create App
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── Optional ──────────────────────────────────────────────────────────────────
GENIUS_ACCESS_TOKEN=your_genius_token
JIOSAAVN_API=https://saavnapi-nine.vercel.app
MAX_PLAYLIST_SONGS=25
MAX_SEARCH_RESULTS=6
PORT=8080
