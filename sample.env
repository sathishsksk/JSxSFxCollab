# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_API_ID=your_api_id_from_my.telegram.org
TELEGRAM_API_HASH=your_api_hash_from_my.telegram.org
BOT_ID=YourBotUsernameWithout@

# ── Genius (optional — for lyrics in Spotify/YouTube downloads) ───────────────
GENIUS_ACCESS_TOKEN=your_genius_token

# ── JioSaavn API (default is your Vercel API — no need to change) ─────────────
# JIOSAAVN_API=https://saavnapi-nine.vercel.app

# ── Settings ──────────────────────────────────────────────────────────────────
MAX_PLAYLIST_SONGS=25
PORT=8080

# NOTE: SPOTIFY_CLIENT_ID and SPOTIFY_CLIENT_SECRET are NO LONGER NEEDED.
# Spotify now works via yt-dlp directly — no API keys required.
