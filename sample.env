# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
BOT_ID=YourBotUsernameWithout@

# ── Optional ──────────────────────────────────────────────────────────────────
GENIUS_ACCESS_TOKEN=your_genius_token
JIOSAAVN_API=https://saavnapi-nine.vercel.app
MAX_PLAYLIST_SONGS=25
MAX_SEARCH_RESULTS=6
PORT=8080

# Your Koyeb app public URL — keeps the bot awake (prevents sleeping)
# Find it in: Koyeb dashboard → your app → Domains
APP_URL=https://your-app-name.koyeb.app

# ── NOT NEEDED ANYMORE — DELETE FROM KOYEB ────────────────────────────────────
# SPOTIFY_CLIENT_ID      → DELETE
# SPOTIFY_CLIENT_SECRET  → DELETE
# Spotify now uses web scraping — zero API keys required
