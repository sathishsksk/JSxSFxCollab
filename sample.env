# ── Telegram (Required) ───────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
BOT_ID=YourBotUsername

# ── JioSaavn (Default: your own API — no need to set unless you want to override)
# JIOSAAVN_API=https://saavnapi-nine.vercel.app

# ── Spotify (Required for Spotify links) ─────────────────────────────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── Genius Lyrics (Optional) ──────────────────────────────────────────────────
GENIUS_ACCESS_TOKEN=your_genius_token

# ── Channel for file caching (Optional) ──────────────────────────────────────
DB_CHANNEL_ID=-1001234567890

# ── Settings ──────────────────────────────────────────────────────────────────
MAX_PLAYLIST_SONGS=25
PORT=8080
